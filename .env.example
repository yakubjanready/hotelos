# HotelOS muhit o'zgaruvchilari namunasi
# Ushbu faylni .env nomi bilan nusxalang va qiymatlarni o'zgartiring.

# Redis broker
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Servis portlari
RECEPTION_PORT=8001
HOUSEKEEPING_PORT=8002
ROOMSERVICE_PORT=8003
MAINTENANCE_PORT=8004
DASHBOARD_PORT=8000

# Xavfsizlik
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=admin123

# Ma'lumotlar bazasi
DATABASE_URL=sqlite:///./hotelos.db

# Mehmonxona miqyosi
HOTEL_FLOORS=6
ROOMS_PER_FLOOR=20
